    font-weight: 600;
  }
  
  .twitch-title svg {
    margin-right: 8px;
  }
  
  .twitch-controls {
    display: flex;
    gap: 10px;
  }
  
  .twitch-button {
    background: none;
    border: none;
    color: #efeff1;
    cursor: pointer;
    padding: 5px;
    border-radius: 4px;
  }
  
  .twitch-button:hover {
    background-color: rgba(255,255,255,0.1);
  }
  
  /* Fix placeholder and embed display issues */
  .twitch-embed {
    flex: 1;
    width: 100%;
    height: 100%;
    display: none;
  }
  
  .twitch-stream-placeholder {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #0e0e10;
    color: #efeff1;
    cursor: pointer;
  }
  
  .twitch-stream-placeholder:hover {
    background-color: #1f1f23;
  }
  
  .twitch-placeholder-content {
    text-align: center;
  }
  
  .twitch-placeholder-content svg {
    margin-bottom: 15px;
  }
  
  /* Twitch toggle button styling */
  .twitch-toggle {
    position: fixed;
    bottom: 20px;
    left: 20px;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: #6441a5;
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 2px 5px rgba(0,0,0,0.3);
    z-index: 999;
    transition: all 0.2s ease;
  }
  
  .twitch-toggle.hidden {
    display: none;
  }
  
  .twitch-toggle.active {
    background-color: #9147ff;
    transform: rotate(45deg);
  }
  
  .twitch-toggle:hover {
    transform: scale(1.1);
  }
  
  .twitch-toggle.active:hover {
    transform: scale(1.1) rotate(45deg);
  }
  
  /* Settings panel styling */
  .twitch-settings-panel {
    position: absolute;
    top: 48px;
    right: 0;
    width: 280px;
    background-color: #18181b;
    border: 1px solid #2d2d3a;
