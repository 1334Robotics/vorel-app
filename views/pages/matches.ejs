    padding: 15px;
    z-index: 1001;
  }
  
  .twitch-settings-panel.hidden {
    display: none;
  }
  
  .settings-group {
    margin-bottom: 15px;
  }
  
  .settings-group label {
    display: block;
    margin-bottom: 5px;
    color: #efeff1;
    font-size: 14px;
  }
  
  .settings-group input[type="checkbox"] {
    margin-right: 8px;
  }
  
  .settings-group select,
  .settings-group input[type="text"] {
    width: 100%;
    padding: 8px;
    background-color: #0e0e10;
    border: 1px solid #2d2d3a;
    color: #efeff1;
