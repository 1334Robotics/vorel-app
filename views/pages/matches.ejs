<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Team <%= formattedTeamKey %> Matches</title>
  
  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://vorel.app/?teamKey=<%= formattedTeamKey %>&eventKey=<%= eventKey %>">
  <meta property="og:title" content="Team <%= formattedTeamKey %> Matches at <%= eventName %>">
  <meta property="og:description" content="View match schedule and results for FRC Team <%= formattedTeamKey %> at <%= eventName %>">
  <meta property="og:image" content="https://vorel.app/banner-social3.png">

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:url" content="https://vorel.app/?teamKey=<%= formattedTeamKey %>&eventKey=<%= eventKey %>">
  <meta name="twitter:title" content="Team <%= formattedTeamKey %> Matches at <%= eventName %>">
  <meta name="twitter:description" content="View match schedule and results for FRC Team <%= formattedTeamKey %> at <%= eventName %>">
  <meta name="twitter:image" content="https://vorel.app/banner-social3.png">
  
  <%- include('../partials/styles') %>
  <%- include('../style/style-matches') %>
  <script>
    // Add this before the closing </head> tag to ensure it runs as early as possible
    (function() {
      // Create and add a style tag to ensure refresh overlay is visible immediately
      const style = document.createElement('style');
      style.textContent = '.refresh-overlay { opacity: 1 !important; pointer-events: all !important; }';
      document.head.appendChild(style);
      
      // Remove the style after a short delay to let CSS transitions take over
      setTimeout(() => {
        document.head.removeChild(style);
      }, 100);
    })();
  </script>
  <script>
  // Show loading animation immediately during page load
  document.getElementById('refresh-overlay')?.classList.add('active');
</script>
  <script>
    // This ensures the overlay is visible immediately, even before DOM is ready
    document.addEventListener('DOMContentLoaded', function() {
      const overlay = document.getElementById('refresh-overlay');
      if (overlay) {
        // Don't immediately hide the overlay - wait to see if content loads quickly
        
        // Only hide the overlay once the page is completely loaded
        window.addEventListener('load', function() {
          // Give a small delay to ensure everything is rendered
          setTimeout(() => {
            overlay.classList.remove('active');
          }, 200);
        });
      }
    });
  </script>
  <script>
    // This ensures the overlay is visible immediately, even before DOM is ready
    document.addEventListener('DOMContentLoaded', function() {
      const overlay = document.getElementById('refresh-overlay');
      if (overlay) {
        // Only hide the overlay once the page is completely loaded
        window.addEventListener('load', function() {
          // Give a small delay to ensure everything is rendered
          setTimeout(() => {
            overlay.classList.remove('active');
          }, 200);
        });
      }
    });
  </script>
</head>
<body>
  <!-- Add refresh overlay at the beginning of body -->
  <div id="refresh-overlay" class="refresh-overlay active">
    <div class="refresh-spinner">
      <div class="cube-face front"></div>
      <div class="cube-face back"></div>
      <div class="cube-face right"></div>
      <div class="cube-face left"></div>
      <div class="cube-face top"></div>
      <div class="cube-face bottom"></div>
    </div>
  </div>
  
  <div class="container">
    <div class="header">
      <div class="header-content">
        <img src="/icon.png" alt="Vorel Icon" class="header-icon" />
        <div class="header-subtitle">Team <%= formattedTeamKey %> Matches at <%= eventName %></div>
      </div>
    </div>
    
    <div class="event-info">
      <span>Event: <%= eventName %> (<%= eventKey %>)</span>
      <span class="now-queuing">Now Queuing: <%= nowQueuing || 'N/A' %></span>
    </div>
    
    <% if (typeof errorMessage !== 'undefined' && errorMessage) { %>
    <div class="error-message">
      <strong>Error:</strong> <%= errorMessage %>
    </div>
    <% } %>
    
    <div class="main-container">
      <!-- LEFT COLUMN: Match listings -->
      <div class="matches-column">
        <div class="content">
          <% if (Object.keys(matchGroups).length === 0 && completedMatches.length === 0) { %>
            <div class="no-matches">
              <p>No matches found for team <%= formattedTeamKey %></p>
            </div>
          <% } else { %>
            <!-- Active/Upcoming Matches -->
            <% Object.keys(matchGroups).forEach(groupType => { %>
              <%- include('../partials/matchGroup', { 
                groupType, 
                matches: matchGroups[groupType], 
                formattedTeamKey,
                isCompletedGroup: false,
                isEmbedded: false
              }) %>
            <% }); %>
            
            <!-- Completed Matches -->
            <% if (completedMatches.length > 0) { %>
              <%- include('../partials/matchGroup', { 
                groupType: 'Completed', 
                matches: completedMatches, 
                formattedTeamKey,
                isCompletedGroup: true,
                isEmbedded: false
              }) %>
            <% } %>
          <% } %>
        </div>
      </div>
      
      <!-- RIGHT COLUMN: Team info, next match, and clock -->
      <div class="info-column">
        <!-- Team Ranking Section -->
        <% if (teamRanking) { %>
        <div class="team-ranking-section">
          <div class="info-title">Team <%= formattedTeamKey %> Ranking</div>
          <div class="ranking-stats">
            <div class="stat-card">
              <div class="stat-value">#<%= teamRanking.rank %></div>
              <div class="stat-label">Rank</div>
            </div>
            <div class="stat-card">
              <div class="stat-value"><%= teamRanking.record %></div>
              <div class="stat-label">Record (W-L-T)</div>
            </div>
            <div class="stat-card">
              <div class="stat-value"><%= teamRanking.matchesPlayed || "N/A" %></div>
              <div class="stat-label">Matches Played</div>
            </div>
            <div class="stat-card">
              <div class="stat-value"><%= teamRanking.matches %></div>
              <div class="stat-label">Total Teams</div>
            </div>
          </div>
        </div>
        <% } %>
        
        <!-- Next Match Section -->
        <% 
          let nextMatch = null;
          let nextMatchAlliance = null;
          
          // Find the next match
          if (Object.keys(matchGroups).length > 0) {
            for (const groupType in matchGroups) {
              if (matchGroups[groupType].length > 0) {
                nextMatch = matchGroups[groupType][0];
                nextMatchAlliance = nextMatch.redTeams.includes(formattedTeamKey) ? 'red' : 'blue';
                break;
              }
            }
          }
        %>
        
        <div class="next-match-card">
          <div class="info-title">Next Match</div>
          <div class="next-match-details <%= nextMatch && nextMatch.status === 'Now queuing' ? 'queuing' : '' %>">
            <% if (nextMatch) { %>
              <div class="next-match-number">
                <span><%= nextMatch.label %></span>
              </div>
              <div class="next-match-time" data-timestamp="<%= nextMatch.times.scheduledStartTime || '' %>">
                <% 
                  let nextMatchTimeDisplay = "TBD";
                  if (nextMatch.times.scheduledStartTime) {
                    try {
                      const matchDate = new Date(nextMatch.times.scheduledStartTime);
                      if (!isNaN(matchDate.getTime())) { // Check if the date is valid
                        nextMatchTimeDisplay = matchDate.toLocaleTimeString('en-US', {
                          hour: 'numeric',
                          minute: '2-digit',
                          hour12: true
                        });
                      }
                    } catch (e) {
                      // Keep default "TBD" if date parsing fails
                    }
                  }
                %>
                <%= nextMatchTimeDisplay %>
              </div>

              <% if (nextMatch.times.estimatedStartTime) { %>
                <div class="next-match-estimated" data-timestamp="<%= nextMatch.times.estimatedStartTime || '' %>">
                  <% 
                    let estimatedTimeDisplay = "Est: TBD";
                    try {
                      const estDate = new Date(nextMatch.times.estimatedStartTime);
                      if (!isNaN(estDate.getTime())) { // Check if the date is valid
                        estimatedTimeDisplay = "Est: " + estDate.toLocaleTimeString('en-US', {
                          hour: 'numeric',
                          minute: '2-digit',
                          hour12: true
                        });
                      }
                    } catch (e) {
                      // Keep default if date parsing fails
                    }
                  %>
                  <%= estimatedTimeDisplay %>
                </div>
              <% } %>

              <div class="alliance-indicator <%= nextMatchAlliance %>">
                <div class="alliance-dot <%= nextMatchAlliance %>-alliance"></div>
                <%= nextMatchAlliance.charAt(0).toUpperCase() + nextMatchAlliance.slice(1) %> Alliance
              </div>
              
              <!-- Teams in the match -->
              <div class="next-match-teams">
                <div class="teams-section">
                  <div class="teams-title red-title">Red Alliance</div>
                  <div class="teams-list">
                    <% nextMatch.redTeams.forEach(team => { %>
                      <div class="team-item <%= team === formattedTeamKey ? 'highlight red-highlight' : '' %>">
                        Team <%= team %>
                      </div>
                    <% }); %>
                  </div>
                </div>
                
                <div class="teams-section">
                  <div class="teams-title blue-title">Blue Alliance</div>
                  <div class="teams-list">
                    <% nextMatch.blueTeams.forEach(team => { %>
                      <div class="team-item <%= team === formattedTeamKey ? 'highlight blue-highlight' : '' %>">
                        Team <%= team %>
                      </div>
                    <% }); %>
                  </div>
                </div>
              </div>
              
              <div class="match-status <%= nextMatch.status === 'Now queuing' ? 'status-queuing' : nextMatch.status === 'On deck' ? 'status-on-deck' : nextMatch.status === 'On field' ? 'status-on-field' : 'status-default' %>" style="text-align: center; margin-top: 5px;">
                <%= nextMatch.status %>
              </div>
            <% } else { %>
              <div style="text-align: center; padding: 20px 0; color: var(--text-secondary); font-size: 1.2em;">
                N/A
              </div>
              <div style="text-align: center; color: var(--text-secondary); font-size: 0.9em;">
                No upcoming matches
              </div>
            <% } %>
          </div>
        </div>
        
        <!-- Clock Section -->
        <div class="clock-section">
          <div class="info-title">Current Time</div>
          <div class="clock-display" id="clock-time"></div>
          <div class="clock-date" id="clock-date"></div>
        </div>
      </div>
    </div>
    
    <%- include('../partials/footer', { eventKey }) %>
  </div>
  
  <!-- QR Code Component -->
  <div id="qr-code-container" class="qr-code-container hidden">
    <button class="qr-code-close" onclick="dismissQRCode()">&times;</button>
    <div class="qr-code-title">Scan to open on mobile</div>
    <div id="qr-code" class="qr-code-canvas"></div>
    <div class="qr-code-info">Want this for your team? Scan the QR code</div>
  </div>

  <%- include('../partials/scripts', { eventKey }) %>
  
  <script>
    // Add clock functionality
    function updateClock() {
      const now = new Date();
      
      // Update time
      document.getElementById('clock-time').textContent = now.toLocaleTimeString('en-US', {
        hour: 'numeric',
        minute: '2-digit',
        second: '2-digit',
        hour12: true
      });
      
      // Update date
      document.getElementById('clock-date').textContent = now.toLocaleDateString('en-US', {
        weekday: 'long',
        year: 'numeric',
        month: 'long',
        day: 'numeric'
      });
      
      setTimeout(updateClock, 1000);
    }
    
    document.addEventListener('DOMContentLoaded', function() {
      updateClock();
    });

    // QR Code functionality
    document.addEventListener('DOMContentLoaded', function() {
      // Check if it's a mobile device using a common method
      const isMobile = /Android|iPhone|iPad|iPod|IEMobile|Opera Mini/i.test(navigator.userAgent);
      
      // Check if Web Share API is available (mostly on mobile devices)
      const canShare = navigator.share !== undefined;
      
      // First, check if QR code was previously dismissed
      const qrDismissed = localStorage.getItem('qrDismissed');
      
      if (isMobile || canShare) {
        // On mobile: Convert QR button to share button
        document.getElementById('qr-code-container').classList.add('hidden');
        document.getElementById('qr-code-reopen').innerHTML = `
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92 1.61 0 2.92-1.31 2.92-2.92s-1.31-2.92-2.92-2.92z"/>
          </svg>
        `;
        document.getElementById('qr-code-reopen').classList.add('visible');
        
        // Update the onclick for share functionality
        document.getElementById('qr-code-reopen').onclick = shareContent;
      } else {
        // On desktop
        if (qrDismissed === 'true') {
          // If QR code was dismissed before, show the reopen button
          document.getElementById('qr-code-reopen').classList.add('visible');
        } else {
          // Add QR code script
          const script = document.createElement('script');
          script.src = "https://cdn.jsdelivr.net/npm/qrcode-generator@1.4.4/qrcode.min.js";
          script.onload = generateQRCode;
          document.head.appendChild(script);
          
          // Show QR code after a short delay
          setTimeout(() => {
            document.getElementById('qr-code-container').classList.remove('hidden');
          }, 1500);
        }
      }
    });

    // Share functionality for mobile
    function shareContent() {
      const currentUrl = window.location.href;
      const eventKey = '<%= eventKey %>'; 
      const teamKey = '<%= formattedTeamKey %>'; 
      
      if (navigator.share) {
        navigator.share({
          title: `Team ${teamKey} Matches at <%= eventName %>`,
          text: `Check out Team ${teamKey}'s matches at <%= eventName %>`,
          url: currentUrl
        })
        .then(() => console.log('Share successful'))
        .catch((error) => console.log('Error sharing:', error));
      } else {
        // Fallback if Web Share API is not available
        reopenQRCode();
      }
    }

    function generateQRCode() {
      // Change to home page URL instead of current URL
      const homeURL = window.location.origin; 
      
      // Generate QR code
      const qr = qrcode(0, 'L');
      qr.addData(homeURL);
      qr.make();
      
      // Display QR code
      document.getElementById('qr-code').innerHTML = qr.createImgTag(4);
    }

    function dismissQRCode() {
      // Hide the QR code
      document.getElementById('qr-code-container').classList.add('hidden');
      
      // Remember the dismissal in localStorage
      localStorage.setItem('qrDismissed', 'true');
      
      // Show the reopen button after a short delay
      setTimeout(() => {
        const reopenButton = document.getElementById('qr-code-reopen');
        reopenButton.classList.add('visible');
      }, 300);
    }

    function reopenQRCode() {
      // Hide the reopen button
      document.getElementById('qr-code-reopen').classList.remove('visible');
      
      // Show the QR code container
      document.getElementById('qr-code-container').classList.remove('hidden');
      
      // Ensure we have the QR code library loaded
      if (typeof qrcode !== 'function') {
        const script = document.createElement('script');
        script.src = "https://cdn.jsdelivr.net/npm/qrcode-generator@1.4.4/qrcode.min.js";
        script.onload = generateQRCode;
        document.head.appendChild(script);
      } else {
        // If already loaded, just regenerate the code
        generateQRCode();
      }
    }

    // Add refresh animation instead of page reload
    document.addEventListener('DOMContentLoaded', function() {
      // Existing initialization code...
      updateClock();
      
      // Add refresh animation handling
      setupRefreshAnimation();
    });
    
    // Function to set up the refresh animation logic
    function setupRefreshAnimation() {
      // Get the refresh overlay element
      const refreshOverlay = document.getElementById('refresh-overlay');
      
      // Create a function to intercept the regular reload and replace it with animation
      window.performAnimatedRefresh = function() {
        // Show the animation
        refreshOverlay.classList.add('active');
        
        // After animation completes (1 second), fetch the updated content
        setTimeout(() => {
          // Fetch the same page with the same parameters
          fetch(window.location.href)
            .then(response => response.text())
            .then(html => {
              // Create a temporary element to parse the HTML
              const tempDiv = document.createElement('div');
              tempDiv.innerHTML = html;
              
              // Update the main container content
              const newMainContainer = tempDiv.querySelector('.main-container');
              const currentMainContainer = document.querySelector('.main-container');
              
              if (newMainContainer && currentMainContainer) {
                currentMainContainer.innerHTML = newMainContainer.innerHTML;
              }
              
              // Update the event info section
              const newEventInfo = tempDiv.querySelector('.event-info');
              const currentEventInfo = document.querySelector('.event-info');
              
              if (newEventInfo && currentEventInfo) {
                currentEventInfo.innerHTML = newEventInfo.innerHTML;
              }
              
              // Hide the animation
              refreshOverlay.classList.remove('active');
              
              // Re-initialize any event handlers or scripts that need to run after content update
              updateClock();
            })
            .catch(error => {
              console.error('Error fetching updated content:', error);
              // If there's an error, just do a regular page reload
              refreshOverlay.classList.remove('active');
              window.location.reload();
            });
        }, 1000);  // Wait for animation to complete
      };
      
      // The rest of the setupRefreshAnimation function remains unchanged
      // ...
    }
    
    // Add a spinner animation when the refresh button is clicked
    // This assumes there's a refresh button with id="refresh-button"
    document.addEventListener('click', function(e) {
      if (e.target.id === 'refresh-button' || e.target.closest('#refresh-button')) {
        e.preventDefault();
        performAnimatedRefresh();
      }
    });

    // Update the callback method to use the animated refresh instead of reload
    window._dataCheckCallback = function(changed) {
      if (changed) {
        if (typeof window.performAnimatedRefresh === 'function') {
          window.performAnimatedRefresh();
        } else {
          window.location.reload();  // Fallback if our function isn't available
        }
      }
    };

    // Show the loading animation immediately when script runs (before DOM is ready)
    document.addEventListener('DOMContentLoaded', function() {
      // Hide the loading animation once DOM is fully loaded
      const refreshOverlay = document.getElementById('refresh-overlay');
      if (refreshOverlay) {
        refreshOverlay.classList.remove('active');
      }
      
      // Existing initialization code...
      updateClock();
      setupRefreshAnimation();
    });
  </script>

  <!-- QR Code Reopen Button -->
  <div id="qr-code-reopen" class="qr-code-reopen" onclick="reopenQRCode()">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
      <path d="M3 3h7v7H3V3zm2 2v3h3V5H5zm9-2h7v7h-7V3zm2 2v3h3V5h-3zM3 14h7v7H3v-7zm2 2v3h3v-3H5zm13-2v3h4v-3h-4zm-6 0v7h2v-7h-2zm4 7v-2h-2v2h2z"/>
    </svg>
  </div>

  <!-- Twitch Stream Container -->
<div id="twitch-stream-container" class="twitch-stream-container hidden">
  <div class="twitch-header">
    <div class="twitch-title">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M11.64 5.93H13.07V10.21H11.64M15.57 5.93H17V10.21H15.57M7 2L3.43 5.57V18.43H7.71V22L11.29 18.43H14.14L20.57 12V2M19.14 11.29L16.29 14.14H13.43L11.14 16.43V14.14H7.71V3.43H19.14Z" fill="#6441a5"/>
      </svg>
      <span>Event Stream</span>
    </div>
    <div class="twitch-controls">
      <button id="twitch-settings-toggle" class="twitch-button">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.07-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61 l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41 h-3.84c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35C8.66,5.59,8.12,5.92,7.63,6.29L5.24,5.33c-0.22-0.08-0.47,0-0.59,0.22L2.74,8.87 C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.8,11.69,4.8,12s0.02,0.64,0.07,0.94l-2.03,1.58 c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54 c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.44-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96 c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.47-0.12-0.61L19.14,12.94z M12,15.6c-1.98,0-3.6-1.62-3.6-3.6 s1.62-3.6,3.6-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z" fill="currentColor"/>
        </svg>
      </button>
      <button id="twitch-close" class="twitch-button">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" fill="currentColor"/>
        </svg>
      </button>
    </div>
  </div>
  
  <div id="twitch-settings-panel" class="twitch-settings-panel hidden">
    <div class="settings-group">
      <label>
        <input type="checkbox" id="twitch-always-show"> 
        Always show stream
      </label>
    </div>
    <div class="settings-group">
      <label>Keep open after match completion:</label>
      <select id="twitch-timeout">
        <option value="0">Close immediately</option>
        <option value="60" selected>1 minute</option>
        <option value="300">5 minutes</option>
        <option value="600">10 minutes</option>
        <option value="-1">Until next match</option>
      </select>
    </div>
    <div class="settings-group">
      <label>Twitch channel:</label>
      <input type="text" id="twitch-channel" placeholder="firstinspires">
      <button id="twitch-save" class="twitch-save-btn">Save</button>
    </div>
  </div>
  
  <div id="twitch-stream-placeholder" class="twitch-stream-placeholder">
    <div class="twitch-placeholder-content">
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M11.64 5.93H13.07V10.21H11.64M15.57 5.93H17V10.21H15.57M7 2L3.43 5.57V18.43H7.71V22L11.29 18.43H14.14L20.57 12V2M19.14 11.29L16.29 14.14H13.43L11.14 16.43V14.14H7.71V3.43H19.14Z" fill="#6441a5"/>
      </svg>
      <p>Click to load Twitch stream</p>
    </div>
  </div>
  
  <div id="twitch-embed" class="twitch-embed"></div>
</div>

<!-- Toggle Button -->
<div id="twitch-toggle" class="twitch-toggle">
  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M11.64 5.93H13.07V10.21H11.64M15.57 5.93H17V10.21H15.57M7 2L3.43 5.57V18.43H7.71V22L11.29 18.43H14.14L20.57 12V2M19.14 11.29L16.29 14.14H13.43L11.14 16.43V14.14H7.71V3.43H19.14Z" fill="#6441a5"/>
  </svg>
</div>

<!-- Update Twitch Stream CSS and Script -->
<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Define variables
    let streamVisible = false;
    let streamLoaded = false;
    let streamTimeout = null;
    const isMobile = /Android|iPhone|iPad|iPod|IEMobile|Opera Mini/i.test(navigator.userAgent);
    const STORAGE_PREFIX = 'vorel_twitch_';
    
    // Load settings from localStorage
    const twitchSettings = {
      alwaysShow: localStorage.getItem(`${STORAGE_PREFIX}always_show`) === 'true',
      timeout: parseInt(localStorage.getItem(`${STORAGE_PREFIX}timeout`) || '60'),
      channel: localStorage.getItem(`${STORAGE_PREFIX}channel`) || 'firstinspires'
    };
    
    // Elements
    const twitchContainer = document.getElementById('twitch-stream-container');
    const twitchToggle = document.getElementById('twitch-toggle');
    const twitchClose = document.getElementById('twitch-close');
    const twitchEmbed = document.getElementById('twitch-embed');
    const twitchPlaceholder = document.getElementById('twitch-stream-placeholder');
    const settingsToggle = document.getElementById('twitch-settings-toggle');
    const settingsPanel = document.getElementById('twitch-settings-panel');
    const alwaysShowCheckbox = document.getElementById('twitch-always-show');
    const timeoutSelect = document.getElementById('twitch-timeout');
    const channelInput = document.getElementById('twitch-channel');
    const saveButton = document.getElementById('twitch-save');
    
    // Get page elements
    const mainContainer = document.querySelector('.main-container');
    const pageContainer = document.querySelector('.container');
    const header = document.querySelector('.header');
    const eventInfo = document.querySelector('.event-info');
    
    // Initialize settings in UI
    alwaysShowCheckbox.checked = twitchSettings.alwaysShow;
    timeoutSelect.value = twitchSettings.timeout;
    channelInput.value = twitchSettings.channel;
    
    // Only show Twitch elements on desktop
    if (isMobile) {
      twitchToggle.classList.add('hidden');
      return;
    } else {
      twitchToggle.classList.remove('hidden');
    }
    
    // Initialize stream if always show is enabled
    if (twitchSettings.alwaysShow) {
      setTimeout(() => showStream(), 1000);
    }
    
    // Event listeners
    twitchToggle.addEventListener('click', toggleStream);
    twitchClose.addEventListener('click', hideStream);
    twitchPlaceholder.addEventListener('click', loadAndShowTwitch);
    settingsToggle.addEventListener('click', toggleSettings);
    saveButton.addEventListener('click', saveSettings);
    
    // Handle checkbox changes
    alwaysShowCheckbox.addEventListener('change', function() {
      twitchSettings.alwaysShow = this.checked;
      localStorage.setItem(`${STORAGE_PREFIX}always_show`, this.checked);
    });
    
    // Handle timeout selection
    timeoutSelect.addEventListener('change', function() {
      twitchSettings.timeout = parseInt(this.value);
      localStorage.setItem(`${STORAGE_PREFIX}timeout`, this.value);
    });
    
    // Functions
    function toggleStream() {
      if (streamVisible) {
        hideStream();
      } else {
        showStream();
      }
    }
    
    // Update the showStream and hideStream functions to handle QR code visibility
    function showStream() {
      // Show the stream container
      twitchContainer.classList.remove('hidden');
      twitchToggle.classList.add('active');
      streamVisible = true;
      
      // Apply fixed layout mode to entire page
      document.body.classList.add('with-stream');
      
      // Load Twitch if not already loaded
      if (!streamLoaded) {
        // Just show placeholder initially
        twitchPlaceholder.style.display = 'flex';
        twitchEmbed.style.display = 'none';
      }
      
      // Move team info to top when stream is visible
      reorderContent(true);
      
      // Hide QR code when stream is shown
      const qrCodeContainer = document.getElementById('qr-code-container');
      const qrReopen = document.getElementById('qr-code-reopen');
      
      // Store current QR state before hiding it
      if (qrCodeContainer && !qrCodeContainer.classList.contains('hidden')) {
        sessionStorage.setItem('qr_was_visible', 'true');
        qrCodeContainer.classList.add('hidden');
      }
      
      // Also hide the reopen button if visible
      if (qrReopen && qrReopen.classList.contains('visible')) {
        qrReopen.classList.remove('visible');
        sessionStorage.setItem('qr_reopen_visible', 'true');
      }
    }

    function hideStream() {
      // Hide the stream container
      twitchContainer.classList.add('hidden');
      twitchToggle.classList.remove('active');
      streamVisible = false;
      
      // Remove fixed layout mode from page
      document.body.classList.remove('with-stream');
      
      // Restore original content order
      reorderContent(false);
      
      // Clear any auto-close timeouts
      if (streamTimeout) {
        clearTimeout(streamTimeout);
        streamTimeout = null;
      }
      
      // Restore QR code visibility if it was visible before
      const qrCodeContainer = document.getElementById('qr-code-container');
      const qrReopen = document.getElementById('qr-code-reopen');
      const wasQrVisible = sessionStorage.getItem('qr_was_visible') === 'true';
      const wasReopenVisible = sessionStorage.getItem('qr_reopen_visible') === 'true';
      
      // Don't restore if user manually dismissed the QR code
      const qrDismissed = localStorage.getItem('qrDismissed') === 'true';
      
      if (wasQrVisible && !qrDismissed) {
        qrCodeContainer.classList.remove('hidden');
        sessionStorage.removeItem('qr_was_visible');
      } else if (wasReopenVisible && !qrCodeContainer.classList.contains('hidden')) {
        qrReopen.classList.add('visible');
        sessionStorage.removeItem('qr_reopen_visible');
      }
    }
    
    // Function to reorder content for better layout with stream
    function reorderContent(streamActive) {
      const matchesColumn = document.querySelector('.matches-column');
      const infoColumn = document.querySelector('.info-column');
      
      if (streamActive && matchesColumn && infoColumn) {
        // Move team info/ranking above matches when stream is active
        mainContainer.insertBefore(infoColumn, matchesColumn);
      } else if (!streamActive && matchesColumn && infoColumn) {
        // Restore original order (matches column first, then info column)
        mainContainer.insertBefore(matchesColumn, infoColumn);
      }
    }
    
    function loadAndShowTwitch() {
      // Properly hide placeholder and show embed
      twitchPlaceholder.style.display = 'none';
      twitchEmbed.style.display = 'block';
      
      // Load Twitch embed if not already loaded
      if (!streamLoaded) {
        loadTwitchEmbed();
        streamLoaded = true;
      }
    }
    
    function loadTwitchEmbed() {
      // Clean any previous embed
      twitchEmbed.innerHTML = '';
      
      // Add Twitch embed script
      const script = document.createElement('script');
      script.src = "https://embed.twitch.tv/embed/v1.js";
      
      script.onload = function() {
        new Twitch.Embed("twitch-embed", {
          width: "100%",
          height: "100%",
          channel: twitchSettings.channel,
          layout: "video",
          autoplay: true,
          parent: [window.location.hostname]
        });
      };
      
      document.body.appendChild(script);
    }
    
    function toggleSettings() {
      settingsPanel.classList.toggle('hidden');
    }
    
    function saveSettings() {
      const newChannel = channelInput.value.trim();
      
      if (newChannel && newChannel !== twitchSettings.channel) {
        twitchSettings.channel = newChannel;
        localStorage.setItem(`${STORAGE_PREFIX}channel`, newChannel);
        
        // Reload the embed if it was loaded before
        if (streamLoaded) {
          loadTwitchEmbed();
        }
      }
      
      // Hide settings panel
      settingsPanel.classList.add('hidden');
    }
    
    // Auto-show stream when specific match conditions occur
    function checkMatchStateForStream() {
      // Find match that's "On field"
      const matchesOnField = document.querySelectorAll('.match-card[data-status="On field"]');
      
      // Find if alliance selection is happening (look for specific text)
      const allianceSelection = document.querySelector('.match-card[data-label*="Alliance Selection"]');
      
      // Check if next match is queuing
      const nextMatchQueuing = document.querySelector('.next-match-details.queuing');
      
      const shouldShowStream = matchesOnField.length > 0 || allianceSelection || nextMatchQueuing;
      
      if (shouldShowStream && !streamVisible) {
        showStream();
      }
      
      // Handle completed matches
      if (matchesOnField.length === 0 && !allianceSelection && !nextMatchQueuing && !twitchSettings.alwaysShow) {
        // If stream is visible and no ongoing activity, start timeout to hide
        if (streamVisible && !streamTimeout && twitchSettings.timeout > 0) {
          streamTimeout = setTimeout(() => {
            hideStream();
            streamTimeout = null;
          }, twitchSettings.timeout * 1000);
        }
      }
    }
    
    // Check match states initially
    setTimeout(checkMatchStateForStream, 2000);
    
    // Periodically check match states (every 10 seconds)
    setInterval(checkMatchStateForStream, 10000);
    
    // When data refreshes, check again
    if (window._dataCheckCallback) {
      const originalCallback = window._dataCheckCallback;
      window._dataCheckCallback = function(changed) {
        originalCallback(changed);
        if (changed) {
          // Data changed, re-evaluate after a short delay to let DOM update
          setTimeout(checkMatchStateForStream, 1000);
        }
      };
    }
  });
</script>

<style>
  /* Fixed position layout for stream that doesn't interfere with scroll */
  .twitch-stream-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 65%;
    height: 100%;
    background-color: #0e0e10;
    z-index: 1000;
    display: flex;
    flex-direction: column;
    transition: transform 0.3s ease;
  }
  
  .twitch-stream-container.hidden {
    transform: translateX(-100%);
  }
  
  /* Fixed layout for entire page when stream is active */
  body.with-stream .container {
    margin-left: 65%;
    width: 35%;
    max-width: none;
    transition: margin-left 0.3s ease, width 0.3s ease;
  }
  
  /* Ensure header and event info also move with the content */
  body.with-stream .header,
  body.with-stream .event-info {
    width: 100%;
    max-width: none;
  }
  
  /* When stream is active, stack columns and reorder */
  body.with-stream .main-container {
    flex-direction: column;
    padding: 0 10px;
    max-width: 100%;
    box-sizing: border-box;
  }
  
  body.with-stream .info-column,
  body.with-stream .matches-column {
    width: 100%;
    max-width: 100%;
    padding-left: 10px;
    padding-right: 10px;
  }
  
  body.with-stream .info-column {
    margin-bottom: 15px;
    padding: 0;
  }
  
  body.with-stream .matches-column {
    padding: 0;
  }
  
  /* Fix team lists in mobile style view */
  body.with-stream .next-match-teams {
    display: flex;
    flex-direction: column;
  }

  body.with-stream .teams-section {
    margin-bottom: 10px;
  }

  /* Make event info wrap properly */
  body.with-stream .event-info {
    flex-wrap: wrap;
  }

  /* Adjust the event info spacing */
  body.with-stream .event-info span {
    margin-right: 10px;
    margin-bottom: 5px;
  }

  /* Create better spacing in match cards */
  body.with-stream .match-card {
    padding: 8px;
    margin-bottom: 8px;
  }
  
  /* Fix twitch embed and placeholder styling */
  .twitch-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 15px;
    background-color: #18181b;
    border-bottom: 1px solid #2d2d3a;
  }
  
  .twitch-title {
    display: flex;
    align-items: center;
