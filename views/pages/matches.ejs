  }
  
  .twitch-save-btn {
    margin-top: 8px;
    padding: 5px 10px;
    background-color: #9147ff;
    border: none;
    color: white;
    border-radius: 4px;
    cursor: pointer;
  }
  
  .twitch-save-btn:hover {
    background-color: #772ce8;
  }
  
  /* Fix scrolling issues and prevent status getting stretched off-screen */
body.with-stream .matches-column .content {
  max-height: calc(100vh - 350px);
  overflow-y: auto;
  padding-right: 5px;
  /* Make sure scrolling works properly */
  -webkit-overflow-scrolling: touch;
}

/* Fix status indicators stretching off screen */
body.with-stream .match-status,
body.with-stream .status-queuing,
body.with-stream .status-on-deck,
body.with-stream .status-on-field,
body.with-stream .status-default {
  max-width: 100%;
  white-space: normal;
  word-break: break-word;
  overflow-wrap: break-word;
}

/* Make sure the match cards fit properly when stream is active */
body.with-stream .match-card {
  max-width: 100%;
  width: 100%;
  box-sizing: border-box;
}

/* Fix height and prevent stretching of status containers */
body.with-stream .next-match-details {
  max-width: 100%;
}

/* Improve match content scrolling area */
body.with-stream .matches-column .content {
  /* Increase the height to ensure more content is visible */
  max-height: calc(100vh - 320px);
  /* Add padding to prevent content touching the edge */
  padding: 0 5px 5px 0;
  /* Improve scrollbar appearance */
  scrollbar-width: thin;
}

/* Make sure all content within the container respects boundaries */
body.with-stream .match-card,
body.with-stream .match-group,
body.with-stream .ranking-stats,
body.with-stream .next-match-card,
body.with-stream .clock-section {
  max-width: 100%;
  overflow-x: hidden;
}

/* Use flexbox for better layout control in the status indicators */
body.with-stream .match-status {
  display: inline-block;
  text-align: center;
  width: auto;
  padding: 2px 8px;
}

/* Make sure we can see all team info when compressed */
body.with-stream .teams-list {
  max-width: 100%;
  overflow-wrap: break-word;
}
</style>
</body>
